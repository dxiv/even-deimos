{
  "name": "even-deimos",
  "version": "0.5.0",
  "private": true,
  "description": "Deimos — Hub app: multi-model chat on phone, streaming HUD on G2.",
  "license": "MIT",
  "type": "module",
  "keywords": ["even-realities", "even-g2", "even-hub", "deimos", "ai"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "build": "npm run test && tsc --noEmit && vite build",
    "preview": "vite preview",
    "sim": "evenhub-simulator \"http://localhost:5173/?simExitParity=1\"",
    "hub:qr": "evenhub qr --url http://localhost:5173",
    "pack:hub": "npm run build && npx evenhub pack app.json dist -o deimos.ehpk",
    "tether:bridge": "node scripts/tether-bridge.mjs"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.10"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.13",
    "@evenrealities/evenhub-simulator": "^0.7.3",
    "typescript": "~5.7.2",
    "vite": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
